# GCP
PROJECT_ID=your-project-id
REGION=us-central1
ZONE=us-central1-a

# Storage
DATA_BUCKET=your-project-id-data
ARTIFACTS_BUCKET=your-project-id-artifacts

# BigQuery
BQ_DATASET=medical_coding
BQ_NOTES_TABLE=clinical_notes
BQ_CODES_TABLE=note_codes

# Artifact Registry
ARTIFACT_REGISTRY=medical-coding

# Vertex AI
VERTEX_PIPELINE_ROOT=gs://your-project-id-artifacts/pipelines

# MLflow (Cloud Run service URL after deploy)
MLFLOW_TRACKING_URI=https://mlflow-XXXXX.run.app

# Service accounts
TRAINING_SA=vertex-training@your-project-id.iam.gserviceaccount.com
SERVING_SA=cloud-run-serving@your-project-id.iam.gserviceaccount.com